{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Docker Services (PostGIS + Redis + API)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "Frontend (Vite + React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend", "--", "--port", "5174"],
      "port": 5174,
      "autoPort": false
    },
    {
      "name": "Backend (Uvicorn standalone)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--app-dir", "backend"],
      "port": 8000
    }
  ]
}
